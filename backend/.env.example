PORT=3001

# OAuth client ID from Google Cloud Console (Credentials → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=

# Secret used to sign session tokens — set this to a long random string
JWT_SECRET=

# Turso database (https://turso.tech) — create a database and copy these from
# `turso db show <db-name>` (URL) and `turso db tokens create <db-name>` (token)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Cloudinary (https://cloudinary.com) — from your dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
